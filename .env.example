# Ollama (always attempted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Cloud providers (optional — set key to activate backend)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AI...

# Auth (disabled by default for local development)
AUTH_ENABLED=false
# FABRICAI_API_KEYS=sk-fabricai-key1,sk-fabricai-key2

# Rate limiting (requests per minute per key/IP)
RATE_LIMIT_RPM=60

# Logging ("text" for development, "json" for production)
LOG_FORMAT=text
LOG_LEVEL=INFO

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
QUEUE_MAX_SIZE=10
MAX_CONCURRENT_REQUESTS=4
